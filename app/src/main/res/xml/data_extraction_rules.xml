<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules. Nothing this app holds should be
     copied off the device: filesDir contains the node's private identity
     key, the encrypted vault, and com message history. Both cloud backup
     and device-to-device transfer are refused outright. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
